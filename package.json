{
  "name": "travel-planner-graphql-api",
  "version": "0.1.0",
  "description": "This is a GraphQL API that supports a travel planning application.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "watch": "nodemon --exec ts-node src/index.ts"
  },
  "dependencies": {
    "apollo-server": "^3.11.1",
    "dotenv": "^16.3.1",
    "graphql": "^16.7.1",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.14.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
